PAYLOAD_SECRET=your_payload_secret_here
DATABASE_URI=postgres://postgres:password@localhost:5432/framehouse_hub

COMPANY_NAME="Framehouse"
TWITTER_CREATOR="@framehouse"
TWITTER_SITE="https://framehouseworks.com"
SITE_NAME="Framehouse Hub"

PAYLOAD_PUBLIC_SERVER_URL=https://hub.framehouseworks.com
NEXT_PUBLIC_SERVER_URL=https://hub.framehouseworks.com

# Used to preview drafts
PREVIEW_SECRET=demo-draft-secret

# Stripe API keys
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOKS_SIGNING_SECRET=whsec_

# GCS Storage (for production/containers)
GCS_BUCKET=your-bucket-name
GCS_PROJECT_ID=your-project-id
# GCS_CREDENTIALS='{"type": "service_account", ...}'

# Seeding & Initial Setup
# PAYLOAD_SECRET is mandatory for running 'npm run seed'
# NEXT_PUBLIC_SERVER_URL is used for dynamic asset resolution during seeding
# SEED_SECRET is used for authorizing remote seeding via /api/seed-hub?secret=...
SEED_SECRET=your_random_seed_secret_here
